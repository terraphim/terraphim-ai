#!/usr/bin/env bash
# adf-e2e-validate: End-to-end validation of the ADF pipeline.
# Runs a real issue through the complete disciplined development flow
# using opencode agents (not template scripts).
# Produces a validation report in .docs/adf/<issue>/
set -euo pipefail

ADF_DOCS="${ADF_DOCS:-/home/alex/projects/terraphim/terraphim-ai/.docs/adf}"
REPO_DIR="/home/alex/projects/terraphim/terraphim-ai"
GITEA_API="${GITEA_API:-https://git.terraphim.cloud/api/v1}"
GITEA_TOKEN="${GITEA_TOKEN:-}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

usage() {
    printf 'Usage: %s <issue-number> [--skip-phase PHASE] [--dry-run]\n' "$0"
    printf '\nPhases: preflight, research, design, implementation, review, corrections, verification, validation, judge, pr, report\n'
    exit 1
}

issue="${1:-}"
dry_run=false
skip_phases=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --skip-phase) skip_phases+=("$2"); shift 2 ;;
        --dry-run) dry_run=true; shift ;;
        -h|--help) usage ;;
        *) issue="$1"; shift ;;
    esac
done

[[ -z "$issue" ]] && usage

should_skip() {
    local phase="$1"
    for sp in "${skip_phases[@]}"; do
        [[ "$sp" == "$phase" ]] && return 0
    done
    return 1
}

log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*"; }
pass() { printf '%s[PASS]%s %s\n' "$GREEN" "$NC" "$*"; }
fail() { printf '%s[FAIL]%s %s\n' "$RED" "$NC" "$*"; }
warn() { printf '%s[WARN]%s %s\n' "$YELLOW" "$NC" "$*"; }

issue_dir="${ADF_DOCS}/${issue}"
results_file="${issue_dir}/e2e-results.txt"
start_time="$(date +%s)"

mkdir -p "$issue_dir"
: > "$results_file"

phase_preflight() {
    log "=== PREFLIGHT ==="

    log "Checking build..."
    if cargo build -p terraphim_orchestrator --bin adf --bin adf-ctl 2>&1 | tail -1 | grep -q "Finished\|Compiling terraphim_orchestrator"; then
        pass "Build succeeded"
    else
        fail "Build failed"
        return 1
    fi

    log "Checking Gitea access..."
    if [[ -n "$GITEA_TOKEN" ]]; then
        if curl -sf -H "Authorization: token ${GITEA_TOKEN}" "${GITEA_API}/repos/terraphim/terraphim-ai/issues/${issue}" | jq -r '.title' 2>/dev/null | grep -q '.'; then
            pass "Gitea issue #${issue} accessible"
        else
            fail "Cannot access Gitea issue #${issue}"
            return 1
        fi
    else
        warn "GITEA_TOKEN not set"
    fi

    log "Checking model availability..."
    if command -v opencode >/dev/null 2>&1; then
        pass "opencode available"
    else
        fail "opencode not found"
        return 1
    fi

    log "Checking gtr..."
    if command -v gtr >/dev/null 2>&1; then
        pass "gtr available"
    else
        warn "gtr not available (will use API directly)"
    fi

    pass "Preflight complete"
}

run_flow_step() {
    local step_name="$1"
    local timeout="${2:-600}"

    local phase_start
    phase_start="$(date +%s)"

    if cargo run -p terraphim_orchestrator --bin adf-ctl -- \
        --local flow zdp-validate-pipeline \
        --context "issue=${issue}" \
        --step-range "${step_name}" 2>&1 | tee "${issue_dir}/${step_name}-output.log"; then
        local phase_end
        phase_end="$(date +%s)"
        local duration=$((phase_end - phase_start))
        pass "${step_name} completed in ${duration}s"
        echo "${step_name}: PASS (${duration}s)" >> "$results_file"
        return 0
    else
        local phase_end
        phase_end="$(date +%s)"
        local duration=$((phase_end - phase_start))
        fail "${step_name} failed after ${duration}s"
        echo "${step_name}: FAIL (${duration}s)" >> "$results_file"
        return 1
    fi
}

check_artefact() {
    local artefact="$1"
    local path="${issue_dir}/${artefact}"

    if [[ ! -f "$path" ]]; then
        fail "Artefact missing: ${artefact}"
        return 1
    fi

    if grep -q '<!-- Fill in -->' "$path" 2>/dev/null; then
        fail "Artefact has placeholders: ${artefact}"
        return 1
    fi

    if grep -q 'FILL_IN' "$path" 2>/dev/null; then
        fail "Artefact has FILL_IN placeholders: ${artefact}"
        return 1
    fi

    local line_count
    line_count="$(wc -l < "$path")"
    if [[ "$line_count" -lt 20 ]]; then
        warn "Artefact is suspiciously short (${line_count} lines): ${artefact}"
    fi

    pass "Artefact OK: ${artefact} (${line_count} lines)"
    return 0
}

main() {
    log "ADF E2E Validation for issue #${issue}"
    log "Results: ${results_file}"
    echo "=== ADF E2E Validation: Issue #${issue} ===" >> "$results_file"
    echo "Started: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$results_file"

    if ! should_skip "preflight"; then
        phase_preflight || { fail "Preflight failed. Aborting."; exit 1; }
    fi

    if $dry_run; then
        warn "Dry run complete. Use without --dry-run to execute."
        exit 0
    fi

    log "Running zdp-validate-pipeline flow for issue #${issue}..."

    run_flow_step "research" 600 || warn "Research step had issues"
    check_artefact "research.md" || warn "Research artefact check failed"

    run_flow_step "gate-research-content" 10 || fail "Research content gate failed"

    run_flow_step "design" 600 || warn "Design step had issues"
    check_artefact "design.md" || warn "Design artefact check failed"

    run_flow_step "gate-design-content" 10 || fail "Design content gate failed"

    run_flow_step "implementation" 3600 || fail "Implementation step failed"
    check_artefact "implementation-status.md" || warn "Implementation artefact check failed"

    run_flow_step "gate-implementation-content" 10 || fail "Implementation content gate failed"

    run_flow_step "review" 600 || warn "Review step had issues"
    check_artefact "review-findings.md" || warn "Review artefact check failed"

    run_flow_step "corrections-check" 10 || true
    run_flow_step "corrections" 1800 || warn "Corrections step had issues"

    run_flow_step "gate-corrections" 120 || warn "Post-corrections test gate had issues"

    run_flow_step "verification" 600 || warn "Verification step had issues"
    check_artefact "verification-report.md" || warn "Verification artefact check failed"

    run_flow_step "validation" 600 || warn "Validation step had issues"
    check_artefact "validation-report.md" || warn "Validation artefact check failed"

    run_flow_step "final-judge" 300 || warn "Final judge step had issues"
    check_artefact "final-approval-verdict.md" || warn "Judge verdict check failed"

    run_flow_step "create-pr" 60 || warn "PR creation had issues"

    run_flow_step "validation-report" 30 || warn "Report generation had issues"

    local end_time
    end_time="$(date +%s)"
    local total_duration=$((end_time - start_time))

    {
        echo ""
        echo "=== RESULTS ==="
        echo "Total duration: ${total_duration}s"
        echo ""
        echo "=== ARTEFACT INVENTORY ==="
        for f in research.md design.md implementation-status.md review-findings.md verification-report.md validation-report.md final-approval-verdict.md pipeline-validation-report.md; do
            if [[ -f "${issue_dir}/${f}" ]]; then
                lines="$(wc -l < "${issue_dir}/${f}")"
                echo "  ${f}: ${lines} lines"
            else
                echo "  ${f}: MISSING"
            fi
        done
        echo ""
        echo "=== GIT CHANGES ==="
        git diff --stat main..task/${issue}-validation 2>/dev/null || echo "  No branch changes detected"
        echo ""
        echo "Finished: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    } >> "$results_file"

    cat "$results_file"

    log "Validation complete. Report: ${results_file}"
}

main "$@"
