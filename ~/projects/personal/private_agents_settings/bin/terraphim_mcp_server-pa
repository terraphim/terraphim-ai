#!/usr/bin/env bash
# terraphim_mcp_server-pa: MCP server wrapper for the Personal Assistant role.
# This wrapper ensures the MCP server starts correctly when spawned by opencode.
# Key issue: opencode spawns MCP servers without inheriting shell environment,
# so we need to set up the environment here.

set -euo pipefail

# Try to source shell profile to get proper environment (including 1Password account)
if [ -f ~/.profile ]; then
    source ~/.profile 2>/dev/null
elif [ -f ~/.bash_profile ]; then
    source ~/.bash_profile 2>/dev/null
elif [ -f ~/.bashrc ]; then
    source ~/.bashrc 2>/dev/null
elif [ -f ~/.zshrc ]; then
    source ~/.zshrc 2>/dev/null
fi

# Fallback for HOME if still not set
export HOME="${HOME:-$(eval echo ~$(whoami))}"
export OP_ACCOUNT="${OP_ACCOUNT:-my.1password.com}"

# Redirect stderr to log file to prevent opencode from seeing initialization errors
# that could cause it to reject the MCP server connection
exec 2>>/tmp/terraphim_mcp_server.log

JMAP_TOKEN_SOURCE=""

# Load JMAP token from pre-injected file if available
# Run: op inject -i ~/.config/terraphim/jmap.env.tpl -o ~/.config/terraphim/jmap.env
if [ -f "$HOME/.config/terraphim/jmap.env" ]; then
    source "$HOME/.config/terraphim/jmap.env"
    JMAP_TOKEN_SOURCE="injected_file"
    
    # Validate token isn't still a template placeholder
    if [[ "$JMAP_ACCESS_TOKEN" == *"{{ op://"* ]]; then
        echo "ERROR: jmap.env contains unprocessed 1Password template" >&2
        echo "Run: op inject -i ~/.config/terraphim/jmap.env.tpl -o ~/.config/terraphim/jmap.env" >&2
        unset JMAP_ACCESS_TOKEN
        JMAP_TOKEN_SOURCE=""
    fi
fi

# Check if JMAP token is available
if [ -z "${JMAP_ACCESS_TOKEN:-}" ]; then
    echo "WARNING: JMAP_ACCESS_TOKEN is not set. JMAP email search will be disabled." >&2
    echo "To enable: op inject -i ~/.config/terraphim/jmap.env.tpl -o ~/.config/terraphim/jmap.env" >&2
fi

# Use minimal PA-only config to avoid loading all 11 roles (which takes 60s)
CONFIG_DIR="$HOME/.config/terraphim"
PA_CONFIG="$CONFIG_DIR/pa_mcp_config.json"
EMBEDDED_CONFIG="$CONFIG_DIR/embedded_config.json"
BACKUP_CONFIG="$CONFIG_DIR/embedded_config.json.backup"

if [ -f "$PA_CONFIG" ]; then
    # Backup original config (only if backup doesn't already exist)
    if [ ! -f "$BACKUP_CONFIG" ]; then
        cp "$EMBEDDED_CONFIG" "$BACKUP_CONFIG"
    fi
    
    # Install PA-only config
    cp "$PA_CONFIG" "$EMBEDDED_CONFIG"
    
    echo "Using Personal Assistant only config for faster startup" >&2
fi

# Start the MCP server with embedded config
# Note: We don't use 'exec' so we can restore the config after the server exits
# Temporarily disable exit-on-error so we can always restore the config
set +e
"$HOME/.cargo/bin/terraphim_mcp_server" --profile embedded "$@"
SERVER_EXIT=$?
set -e

# Restore original config if backup exists
if [ -f "$BACKUP_CONFIG" ]; then
    mv "$BACKUP_CONFIG" "$EMBEDDED_CONFIG"
fi

exit $SERVER_EXIT
