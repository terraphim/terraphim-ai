[Unit]
Description=Rust build cache (SeaweedFS S3 on fcbr0)
Requires=docker.service
After=docker.service network-online.target
Before=fcctl-web.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=%h/rust-cache-stack
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=120

[Install]
WantedBy=default.target
