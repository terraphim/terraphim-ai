# Source this file to direct rustc through sccache backed by SeaweedFS S3 on fcbr0.
# Live copy on bigbox: ~/.config/rust-cache.env
# ADR: .docs/adr-rust-build-cache-seaweedfs.md
export RUSTC_WRAPPER=/home/alex/.local/bin/sccache
export SCCACHE_BUCKET=rust-cache
export SCCACHE_ENDPOINT=http://172.26.0.1:8333
export SCCACHE_S3_USE_SSL=false
export SCCACHE_REGION=us-east-1
export SCCACHE_S3_KEY_PREFIX=terraphim-ai
# SeaweedFS has auth disabled by default; AWS client libraries still require these to be set.
export AWS_ACCESS_KEY_ID=any
export AWS_SECRET_ACCESS_KEY=any
