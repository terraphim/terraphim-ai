+
+        assert!(
+            executor.session_to_vm.read().contains_key(&session_id),
+            "setup: session map should be populated"
+        );
+
+        // VmManager is None so cleanup skips stop_vm and goes straight to clear.
+        executor.cleanup().await.unwrap();
+
+        assert!(
