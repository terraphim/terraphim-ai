+        );
+        assert!(
+            executor.snapshot_counts.read().is_empty(),
+            "snapshot_counts should be empty after cleanup"
+        );
+        assert!(
+            executor.current_snapshot.read().is_empty(),
+            "current_snapshot should be empty after cleanup"
+        );
