# Environment Variables Example
# Copy this file to .env and fill in the actual values

# crates.io token for publishing Rust crates
# Get this from 1Password: op read "op://TerraphimPlatform/crates.io.token/token"
CARGO_REGISTRY_TOKEN=

# Redis authentication (required when using the 'cache' profile in docker/docker-compose.yml)
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=

# Optional: Local development overrides
# TERRAPHIM_CONFIG=./terraphim_engineer_config.json
# TERRAPHIM_DATA_DIR=./data
# LOG_LEVEL=debug
