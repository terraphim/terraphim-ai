# Generated by Cargo
# will have compiled files and executables
debug/
target/
vendor/
# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# These are backup files generated by rustfmt
**/*.rs.bk
# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb
.vscode/
terraphim-grep/
artifact/
nohup.out
.cargo/
!.cargo/audit.toml
localsearch/
# Local Netlify folder
.netlify/
# mdBook build output
docs/book/
.DS_Store
cargo_vendored
node_modules
desktop/src-tauri/Cargo.lock
docs/src/*.json
#
demo_data/
rust-sdk/
.env
.env.*.password
.aider*
scratchpad/firecracker-rust
scratchpad/
# terraphim_server/dist/ is tracked -- contains pre-built frontend for rust-embed
# Generated build artifacts that shouldn't be committed
.cargo/config.toml
crates/terraphim_atomic_client/.aider.*
docs/src/thesaurus.json
lab/parking-lot/server-poem/.env
website/public/
website/static/video/
website/static/images/terraphim_bg.*
releases/

# Beads task database (local working state)
.beads/

# Learning capture artefacts (auto-generated, machine-local)
.terraphim/learnings/

# Nested crates directories (build artifacts)
crates/**/crates/

# Signing keys (NEVER commit private keys)
keys/

# ADF deployment configs may contain real secrets injected at deploy time.
# Use orchestrator.toml.example as the tracked template; keep the live file local.
# See: https://git.terraphim.cloud/terraphim/terraphim-ai/issues/1546
scripts/adf-setup/**/*.toml.local

# CodeBuff compiled JavaScript files
.codebuff/agents/.agents/*.js

# Working documents (tracked for project documentation)

# Claude Code working files
.claude/plans/

# Auto-updated test settings
crates/terraphim_settings/test_settings/settings.toml
# Nightshift plan artifacts (keep out of version control)
.nightshift-plan

# Build artifacts
a.out

# Cache
.cached-context/
.ruff_cache/
.cachebro/cache.db

# Stale logs and test results
*.log
test-results/
benchmark-results/

# Release tarballs
*.tar.gz

# UI design session artifacts
*.png
ui-session.txt

# Agent skill directories (development artifacts)
.agents/skills/
skills/

# Agent tool directories
.cachebro/
.claude/
.commandcode/
.continue/
.crush/
.factory/
.goose/
.kilocode/
.kiro/
.mcpjam/
.neovate/
.openhands/
.pi/
.qoder/
.qwen/
.roo/
.trae/
.windsurf/
.zencoder/
skills-lock.json

# Playwright test artifacts
.playwright-mcp/

# Pi session logs
pi-session-*.html
*.html

# Git worktree agent scratch directories
.worktrees/

# Client project data - never track
projects/odilo/
# CI test fix verification

# Agent artefact files accidentally committed to repo root (#2342, #2364)
# These patterns match working-copy snapshots and review outputs from
# PR-reviewer/verifier/validator agents that should not be committed.
/pr_review_*.md
/*.pr_gate_result*.rs
/*.reconcile_impl*.rs
/*_new.rs
/*_old.rs
/cursor_*.rs
/session-ses_*.md
/security_audit_report_*.md
/pr_review_files/
# Heredoc accidents (bare EOF/PYEOF files created by malformed shell heredocs)
/EOF
/PYEOF
# Home-directory stubs (literal '~' dir created by unexpanded tilde in git commands)
~/

# === Agent artefact prevention at source (Issue #2413) ===
# Stops ADF/AI agent scratch files from contaminating PRs.
# These extend the root-only patterns above to cover subdirectory
# and additional naming variants found slipping the current rules.

# KG flow-state and agent session scratch
.terraphim/flow-state/
.sessions/
session-ses_*.md

# PR review temp directories and diff files
.pr_review_temp/
pr_review_files/
.pr*.diff
.handoff-*.md

# Merged-doc artefacts (e.g. .docs/foo-pr-2318-merge.md)
.docs/*-pr-*-merge.md

# PR gate and reconcile impl snapshots -- recursive and non-dot variants
# (root-only dot-prefixed versions are already handled above)
pr_gate_result*.rs
reconcile_impl_new.rs
reconcile_impl_old.rs
